DATABASE_URL=postgresql://agro:agropass@localhost:5432/agrofinsense
MONGO_URL=mongodb://localhost:27017/agrofinsense
REDIS_URL=redis://localhost:6379

# Market prices — free tier, register at https://data.gov.in/user/register
AGMARKNET_KEY=

# Geocoding — free 5000 req/day, register at https://locationiq.com
LOCATIONIQ_KEY=pk.YOUR_KEY_HERE

# News — optional, free 200 req/day, register at https://newsdata.io
NEWSDATA_KEY=

# Open-Meteo weather API: completely free, no key needed
# Open-Meteo archive (ERA5): completely free, no key needed
# OpenAQ air quality: completely free, no key needed

# AI models (local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NARRATIVE_MODEL=gemma3:4b
OLLAMA_FAST_MODEL=llama3.2:3b

# Auth
JWT_SECRET=change-me-to-random-64-char-string